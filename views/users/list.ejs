<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <H1>Our Current Users</H1>
    <ul>
    <% 
        let users = locals.users;
        for (user of users){ %>
            <li>
                <%= user.firstName %>
                
                <%= user.lastName %>
                
                <%= user.age %>
                
                <%= user.gender %>  
            </li>
            
    <% } %>
    </ul>
</body>
</html>